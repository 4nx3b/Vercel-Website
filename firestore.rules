rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "asaxxhiii@gmail.com";
    }

    match /amaQuestions/{questionId} {
      allow read: if isAdmin() || resource.data.answered == true;

      allow create: if request.resource.data.keys().hasOnly([
          "name", "question", "answer", "answered", "createdAt", "answeredAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 280
        && request.resource.data.answer == ""
        && request.resource.data.answered == false
        && request.resource.data.answeredAt == null;

      allow update, delete: if isAdmin();
    }
  }
}
